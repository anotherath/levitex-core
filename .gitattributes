# Set default behavior to handle line endings automatically.
* text=auto

# Force LF for shell scripts and specific source files to avoid issues in cross-platform environments.
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Explicitly declare binary files that should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
